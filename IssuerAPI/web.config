<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- ให้ .well-known/* ไปที่ ASP.NET Core แทนที่จะ block -->
    <handlers>
      <add name="WellKnown"
           path=".well-known/*"
           verb="GET"
           modules="AspNetCoreModuleV2"
           resourceType="Unspecified"
           requireAccess="None" />
    </handlers>

    <!-- ASP.NET Core handler หลัก -->
    <aspNetCore processPath="dotnet"
                arguments=".\IssuerAPI.dll"
                stdoutLogEnabled="false"
                stdoutLogFile=".\logs\stdout"
                hostingModel="inprocess" />

  </system.webServer>
</configuration>
